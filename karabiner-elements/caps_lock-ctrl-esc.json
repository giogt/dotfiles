{
    "description": "caps_lock to control, or to escape (if alone)",
    "manipulators": [
        {
            "from": {
                "key_code": "caps_lock",
                "modifiers": { "optional": ["any"] }
            },
            "to": [{ "key_code": "left_control" }],
            "to_if_alone": [{ "key_code": "escape" }],
            "to_if_held_down": [
                {
                    "held_down_milliseconds": 1,
                    "key_code": "left_control"
                }
            ],
            "type": "basic"
        }
    ]
}
