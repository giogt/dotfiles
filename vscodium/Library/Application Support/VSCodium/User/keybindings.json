// Place your key bindings in this file to override the defaults
[
	// open whichkey when in the editor, and neovim is in normal mode
	{
		"key": "space",
		"command": "whichkey.show",
		"when": "editorTextFocus && neovim.mode == normal"
	},
	// open whichkey when the focus is on the sidebar
	{
		"key": "space",
		"command": "whichkey.show",
		"when": "!editorTextFocus && !inputFocus"
	},
	// Easy navigation in quick open/QuickPick
	{
		"key": "ctrl+j",
		"command": "workbench.action.quickOpenSelectNext",
		"when": "inQuickOpen"
	},
	{
		"key": "ctrl+k",
		"command": "workbench.action.quickOpenSelectPrevious",
		"when": "inQuickOpen"
	},
	// Easy navigation in suggestion/intellisense
	{
		"key": "ctrl+j",
		"command": "selectNextSuggestion",
		"when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
	},
	{
		"key": "ctrl+k",
		"command": "selectPrevSuggestion",
		"when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
	},
	{
		"key": "ctrl+l",
		"command": "acceptSelectedSuggestion",
		"when": "suggestWidgetMultipleSuggestions && suggestWidgetVisible && textInputFocus"
	},
	// Easy navigation in parameter hint (i.e. traverse the hints when there's multiple overload for one method)
	{
		"key": "ctrl+j",
		"command": "showNextParameterHint",
		"when": "editorFocus && parameterHintsMultipleSignatures && parameterHintsVisible"
	},
	{
		"key": "ctrl+k",
		"command": "showPrevParameterHint",
		"when": "editorFocus && parameterHintsMultipleSignatures && parameterHintsVisible"
	},
	// Easy navigation in code action
	{
		"key": "ctrl+j",
		"command": "selectNextCodeAction",
		"when": "codeActionMenuVisible"
	},
	{
		"key": "ctrl+k",
		"command": "selectPrevCodeAction",
		"when": "codeActionMenuVisible"
	},
	{
		"key": "ctrl+l",
		"command": "acceptSelectedCodeAction",
		"when": "codeActionMenuVisible"
	},
	// Add ctrl+h/l to navigate in file browser
	{
		"key": "ctrl+h",
		"command": "file-browser.stepOut",
		"when": "inFileBrowser"
	},
	{
		"key": "ctrl+l",
		"command": "file-browser.stepIn",
		"when": "inFileBrowser"
	},
	// Multi diff editor navigation (e.g., the one opened by Git: Open Changes) 
	{
		"key": "ctrl+j",
		"command": "multiDiffEditor.goToNextChange",
		"when": "inMultiDiffEditor"
	},
	{
		"key": "ctrl+k",
		"command": "multiDiffEditor.goToPreviousChange",
		"when": "inMultiDiffEditor"
	}
]