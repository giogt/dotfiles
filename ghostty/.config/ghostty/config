#
# Font
#

font-size = 13.0

font-family = "JetBrainsMono NF"
font-style = "Regular"

font-style-bold = "Bold"
# Use the `Light` style for italic, since I find it more readable than `Italic` in terminals
font-style-italic = "Light"
font-style-bold-italic = "Bold Italic"

#
# Shell
#

copy-on-select = true
cursor-style = block
cursor-style-blink = false
shell-integration = zsh
shell-integration-features = no-cursor,sudo,ssh-terminfo,ssh-env

#
# System
#

confirm-close-surface = false
# quit-after-last-window-closed = true

#
# Window
#

window-padding-x = 15
window-padding-y = 10

window-width = 150
window-height = 50

# disable all window decorations (including titlebar and borders)
#
# Please note that, without window borders, you won't be able to move the window with the mouse,
# not even while holding Cmd + Ctrl.
#
# If you want to remove some decorations and be able to move the window with the mouse, try
# `macos-titlebar-style = hidden` instead (see below)
# window-decoration = none

macos-titlebar-proxy-icon = hidden
# macos-titlebar-style = hidden
macos-window-buttons=hidden

#
# Key Bindings
#

macos-option-as-alt = true

# by default, cmd+enter is bound to toggle full screen
# unbind it by uncommenting the line below
keybind = cmd+enter=unbind

# keybind = option+left=unbind
# keybind = option+right=unbind
#
keybind = global:ctrl+alt+enter=new_window
